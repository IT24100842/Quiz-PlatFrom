PORT=4000

# Spring Boot MySQL profile settings (backend/)
APP_DB_PROFILE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=quiz_platform
DB_USERNAME=root
DB_PASSWORD=root

# Spring Boot SQL Server profile settings (backend/)
# Use these when APP_DB_PROFILE=mssql
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DB=QuizPlatformDB
# Optional full JDBC override (can omit port if needed)
# MSSQL_URL=jdbc:sqlserver://localhost;databaseName=QuizPlatformDB;integratedSecurity=true;encrypt=true;trustServerCertificate=true
MSSQL_INTEGRATED_SECURITY=true
MSSQL_USERNAME=
MSSQL_PASSWORD=
MSSQL_ENCRYPT=true
MSSQL_TRUST_SERVER_CERT=true

# Gmail SMTP settings (for the Node OTP server in /src)
GMAIL_USER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_gmail_app_password
MAIL_FROM=yourgmail@gmail.com

# Google Sign-In OAuth (backend)
GOOGLE_AUTH_ENABLED=false
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=http://localhost:8080/api/auth/oauth/google/callback


# OTP settings
OTP_EXPIRY_MINUTES=5

# Password hashing settings
BCRYPT_SALT_ROUNDS=10
